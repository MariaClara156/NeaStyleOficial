<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NeaStyle Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg nea-navbar">
            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand nea-brand" asp-controller="Administrador" asp-action="Index">
                    Nea<span>Style</span>
                    <small>ADMIN</small>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarAdmin">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarAdmin">

                    <!-- LINKS CENTRAIS -->
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link nea-link" asp-controller="Administrador" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nea-link" asp-controller="Administrador" asp-action="ListarProdutos">
                                <i class="bi bi-archive"></i> Estoque
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nea-link" asp-controller="Administrador" asp-action="GerenciarPedidos">
                                <i class="bi bi-receipt"></i> Pedidos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nea-link" asp-controller="Administrador" asp-action="Relatorio">
                                <i class="bi bi-bar-chart-line"></i> Relatórios
                            </a>
                        </li>
                    </ul>

                    <!-- ÍCONES DIREITA -->
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link nea-icon" asp-controller="Login" asp-action="Logout" title="Sair">
                                <i class="bi bi-box-arrow-right"></i>
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="nea-footer mt-5">
        <div class="container">
            <hr class="nea-footer-hr">
            <p class="text-center nea-footer-copy">© 2026 NeaStyle Modas — Painel Administrativo</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>