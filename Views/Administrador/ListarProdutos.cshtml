@model List<NeaStyleOficial.Models.Catalog.Produto>

@{
    ViewData["Title"] = "Produtos";
}
   <!--Lógica com C# para exibir produtos do banco--->
    <div class="row">
        @foreach (var produto in Model)
        {
            <div class="col-md-4 col-sm-6 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="~/images/produtos/@produto.ImagemUrl" width="100" class="card-img-top" alt="@produto.Nome" style="height: 200px; object-fit: cover;">
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@produto.Nome</h5>
                        <p class="card-text text-muted small">@produto.Descricao</p>
                        <h6 class="mt-auto text-primary">R$ @produto.Preco.ToString("F2")</h6>
                        
                        <div class="d-grid gap-2 mt-3">
                            <button class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-heart"></i> Favoritar
                            </button>
                            <a asp-action="AdicionarCarrinho" asp-route-id="@produto.ProdutoId" class="btn btn-success">
                                <i class="bi bi-cart-plus"></i> Comprar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!--Navegação de produtos dentro da página--->
      <div class="pagination">
        <button class="page-button active">1</button>
        <button class="page-button">2</button>
        <button class="page-button">3</button>
        <button class="page-button">Próxima</button>
      </div>
  </section>
</div>