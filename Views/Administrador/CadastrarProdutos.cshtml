@model NeaStyleOficial.ViewModels.Catalog.CadastrarProdutoViewModel

@{
    ViewData["Title"] = "Cadastro Produto";
    Layout = "_LayoutAdmin";
}
    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card p-4 shadow" style="width: 400px;">
            
            <h2 class="text-center mb-4">NeaStyle</h2>
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var erro in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@erro.ErrorMessage</p>
                    }
                </div>
            }

            <form asp-action="CadastrarProdutos" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome do Produto</label>
                    <input asp-for="Nome" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Descricao" class="form-label">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Categoria" class="form-label">Categoria</label>
                    <select asp-for="Categoria" class="form-select"
                            asp-items="Html.GetEnumSelectList<NeaStyleOficial.Models.Catalog.CategoriaProduto>()">
                        <option value="">Selecione...</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Tipo" class="form-label">Tipo do Produto</label>
                    <select asp-for="Tipo" class="form-select"
                            asp-items="Html.GetEnumSelectList<NeaStyleOficial.Models.Catalog.TipoProduto>()">
                        <option value="">Selecione...</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary w-100">Cadastrar Produto</button>
            </form>
        </div>
    </div>