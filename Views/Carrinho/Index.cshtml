@model NeaStyleOficial.ViewModels.Collections.CarrinhoViewModel
@{
    ViewData["Title"] = "Meu Carrinho";
    Layout = "_Layout";
}

<div class="container mt-5 mb-5">
    <h2 class="mb-4" style="font-family: 'Cormorant Garamond', serif; font-weight: 300;">
        Meu Carrinho
    </h2>

    @if (!Model.Itens.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag text-muted" style="font-size: 4rem;"></i>
            <p class="mt-3 text-muted">Seu carrinho está vazio.</p>
            <a asp-controller="Produto" asp-action="Index" class="btn btn-dark mt-2">
                Ver Produtos
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
        
            <div class="col-12 col-md-8">
                @foreach (var item in Model.Itens)
                {
                    <div class="d-flex gap-3 align-items-center border-bottom py-3">

                        @if (!string.IsNullOrEmpty(item.ImagemUrl))
                        {
                            <img src="~/images/produtos/@item.ImagemUrl"
                                 alt="@item.NomeProduto"
                                 class="rounded"
                                 style="width: 100px; height: 120px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                 style="width: 100px; height: 120px;">
                                <i class="bi bi-image text-muted fs-3"></i>
                            </div>
                        }

                        <div class="flex-grow-1">
                            <p class="fw-semibold mb-1">@item.NomeProduto</p>
                            <p class="text-muted small mb-1">@item.Variacao</p>
                            <p class="text-muted small mb-0">
                                @item.Quantidade x R$ @item.PrecoUnitario.ToString("N2")
                            </p>
                        </div>

                        <div class="text-end">
                            <p class="fw-semibold mb-2">R$ @item.Subtotal.ToString("N2")</p>
                            <form asp-controller="Carrinho" asp-action="RemoverProduto" method="post">
                                <input type="hidden" name="produtoVariacaoId" value="@item.ProdutoVariacaoId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Remover
                                </button>
                            </form>
                        </div>

                    </div>
                }
            </div>

            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm p-4">
                    <h5 class="mb-4" style="font-family: 'Cormorant Garamond', serif;">Resumo do Pedido</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span>R$ @Model.Total.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Frete</span>
                        <span class="text-success">Grátis</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-semibold mb-4">
                        <span>Total</span>
                        <span>R$ @Model.Total.ToString("N2")</span>
                    </div>

                    <form asp-controller="Pedido" asp-action="CriarPedido" method="post">
                        <button type="submit" class="btn btn-dark w-100 btn-lg">
                            Finalizar Pedido
                        </button>
                    </form>

                    <a asp-controller="Produto" asp-action="Index"
                       class="btn btn-outline-dark w-100 mt-2">
                        Continuar Comprando
                    </a>
                </div>
            </div>

        </div>
    }
</div>