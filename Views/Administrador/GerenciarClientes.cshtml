@model IEnumerable<NeaStyleOficial.Models.Users.Cliente>
@{
    ViewData["Title"] = "Clientes";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-family: 'Cormorant Garamond', serif; font-weight: 300;">
            Clientes
        </h2>
        <span class="text-muted small">@Model.Count() cliente(s) cadastrado(s)</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
            <p class="mt-3 text-muted">Nenhum cliente cadastrado ainda.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Telefone</th>
                            <th>CPF</th>
                            <th>Nascimento</th>
                            <th>Pedidos</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="text-muted small">@c.UsuarioId</td>
                                <td class="fw-semibold">@c.Nome</td>
                                <td class="text-muted small">@c.Email</td>
                                <td>@c.Telefone</td>
                                <td class="text-muted small">@c.CPF</td>
                                <td class="text-muted small">@c.DataNascimento.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-dark">@c.Pedidos.Count pedido(s)</span>
                                </td>
                                <td class="text-center">
                                    <form asp-controller="Administrador"
                                          asp-action="DeletarClienteConfirmado"
                                          method="post"
                                          onsubmit="return confirm('Tem certeza que deseja excluir @c.Nome?')">
                                        <input type="hidden" name="usuarioId" value="@c.UsuarioId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Excluir
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>