@model NeaStyleOficial.ViewModels.Users.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">

    <h2 class="mb-4">Dashboard</h2>

    <!-- CARDS RESUMO -->
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-receipt fs-2 text-dark"></i>
                    <h5 class="mt-2">@Model.TotalPedidos</h5>
                    <small class="text-muted">Pedidos</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-currency-dollar fs-2 text-dark"></i>
                    <h5 class="mt-2">R$ @Model.TotalVendas.ToString("N2")</h5>
                    <small class="text-muted">Total em Vendas</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-people fs-2 text-dark"></i>
                    <h5 class="mt-2">@Model.TotalClientes</h5>
                    <small class="text-muted">Clientes</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-box-seam fs-2 text-dark"></i>
                    <h5 class="mt-2">@Model.TotalProdutos</h5>
                    <small class="text-muted">Produtos</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- PRODUTOS MAIS VENDIDOS -->
        <div class="col-12 col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <i class="bi bi-trophy"></i> Produtos Mais Vendidos
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Produto</th>
                                <th>Qtd</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.ProdutosMaisVendidos.Count; i++)
                            {
                                var p = Model.ProdutosMaisVendidos[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@p.NomeProduto</td>
                                    <td>@p.QuantidadeVendida</td>
                                    <td>R$ @p.TotalGerado.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- VENDAS POR MÊS -->
        <div class="col-12 col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <i class="bi bi-bar-chart-line"></i> Vendas por Mês
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mês</th>
                                <th>Pedidos</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model.VendasPorMes)
                            {
                                <tr>
                                    <td>@v.Mes</td>
                                    <td>@v.Quantidade</td>
                                    <td>R$ @v.Total.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

</div>