@model NeaStyleOficial.Models.Catalog.Produto

@{
    ViewData["Title"] = "Detalhes do Produto";
}

<div class="container mt-5">
    <div class="row">
        <!-- Lado Esquerdo: Imagem -->
        <div class="col-md-6">
            <img src="~/images/produtos/@Model.ImagemUrl" class="img-fluid rounded shadow" alt="@Model.Nome">
        </div>

        <!-- Lado Direito: Opções -->
        <div class="col-md-6">
            <h1>@Model.Nome</h1>
            <h3 class="text-primary">R$ @Model.Preco.ToString("F2")</h3>
            <p class="text-muted">@Model.Descricao</p>

            <form asp-action="AdicionarAoCarrinho" method="post" class="mt-4">
                <input type="hidden" name="ProdutoId" value="@Model.ProdutoId" />


                <!-- Quantidade -->
                <div class="mb-3">
                    <label class="form-label">Quantidade</label>
                    <input type="number" name="quantidade" value="1" 
                           min="1" max="10" class="form-control" />
                </div>

                <button type="submit" class="btn btn-success btn-lg w-100">
                    <i class="bi bi-cart-check"></i> Confirmar e Adicionar
                </button>
            </form>
        </div>
    </div>
</div>