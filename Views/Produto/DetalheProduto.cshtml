@model NeaStyleOficial.ViewModels.Catalog.DetalheProdutoViewModel
@{
    ViewData["Title"] = Model.Produto.Nome;
    Layout = "_Layout";
}

<div class="container mt-5 mb-5">
    <div class="row g-5">

        <!-- IMAGEM -->
        <div class="col-12 col-md-6">
            @{
                var primeiraImagem = Model.Variacoes.FirstOrDefault()?.ImagemUrl;
            }
            @if (!string.IsNullOrEmpty(primeiraImagem))
            {
                <img id="imgPrincipal"
                     src="~/images/produtos/@primeiraImagem"
                     alt="@Model.Produto.Nome"
                     class="img-fluid rounded shadow w-100"
                     style="object-fit: cover; max-height: 500px;" />
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                     style="height: 400px;">
                    <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                </div>
            }

            <!-- MINIATURAS -->
            @if (Model.Variacoes.Count > 1)
            {
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    @foreach (var v in Model.Variacoes)
                    {
                        @if (!string.IsNullOrEmpty(v.ImagemUrl))
                        {
                            <img src="~/images/produtos/@v.ImagemUrl"
                                 alt="@v.Cor"
                                 class="rounded border"
                                 style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;"
                                 onclick="document.getElementById('imgPrincipal').src = this.src" />
                        }
                    }
                </div>
            }
        </div>

        <!-- DETALHES -->
        <div class="col-12 col-md-6 d-flex flex-column justify-content-center">

            <p class="text-muted mb-1">@Model.Produto.Categoria — @Model.Produto.Tipo</p>
            <h1 class="mb-2">@Model.Produto.Nome</h1>
            <h3 class="mb-3" id="precoExibido">
                R$ @Model.Variacoes.FirstOrDefault()?.Preco.ToString("F2")
            </h3>

            @if (!string.IsNullOrEmpty(Model.Produto.Descricao))
            {
                <p class="text-muted mb-4">@Model.Produto.Descricao</p>
            }

            <form asp-controller="Carrinho" asp-action="AdicionarAoCarrinho" method="post">

                <!-- SELECT VARIAÇÃO -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Variação</label>
                    <select name="produtoVariacaoId" class="form-select" id="selectVariacao"
                            onchange="atualizarVariacao(this)">
                        @foreach (var v in Model.Variacoes)
                        {
                            <option value="@v.ProdutoVariacaoId"
                                    data-preco="@v.Preco.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                    data-imagem="@v.ImagemUrl"
                                    data-estoque="@v.Estoque">
                                @v.Tamanho — @v.Cor
                            </option>
                        }
                    </select>
                </div>

                <!-- QUANTIDADE -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">Quantidade</label>
                    <input type="number" name="quantidade" value="1" min="1" 
                    max="@Model.Variacoes.FirstOrDefault()?.Estoque" 
                    class="form-control" id="inputQuantidade" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark btn-lg flex-grow-1">
                        <i class="bi bi-bag-plus"></i> Adicionar ao Carrinho
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function atualizarVariacao(select) {
        const opt = select.options[select.selectedIndex];

        const preco = opt.getAttribute("data-preco");
        document.getElementById("precoExibido").textContent = "R$ " + parseFloat(preco).toLocaleString("pt-BR", { minimumFractionDigits: 2 });

        const imagem = opt.getAttribute("data-imagem");
        const imgEl  = document.getElementById("imgPrincipal");
        if (imgEl && imagem) imgEl.src = "/images/produtos/" + imagem;

        // ← ADICIONA: atualiza o max de quantidade com o estoque da variação
        const estoque = opt.getAttribute("data-estoque");
        document.getElementById("inputQuantidade").max = estoque;
    }
    </script>
}