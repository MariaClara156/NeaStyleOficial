@model NeaStyleOficial.Models.Users.Cliente
@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow" style="width: 400px;">

        <h2 class="text-center mb-4">NeaStyle</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var erro in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0 small">@erro.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="EditarPerfil" method="post">
            <input type="hidden" asp-for="UsuarioId" />
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Senha" />

            <div class="mb-3">
                <label class="form-label">Email (Não pode ser alterado)</label>
                <input asp-for="Email" class="form-control bg-light" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Nome Completo</label>
                <input asp-for="Nome" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">CPF</label>
                <input asp-for="CPF" id="cpf" class="form-control"
                       placeholder="000.000.000-00" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Endereço</label>
                <input asp-for="Endereco" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Telefone</label>
                <input asp-for="Telefone" id="telefone" class="form-control"
                       placeholder="(00) 00000-0000" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Data de Nascimento</label>
                <input asp-for="DataNascimento" class="form-control" type="date" required />
            </div>

            <button type="submit" class="btn btn-dark w-100">Salvar Alterações</button>
            <div class="text-center mt-3">
                <a asp-action="Perfil" class="text-muted small">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        $('#cpf').mask('000.000.000-00');
        $('#telefone').mask('(00) 00000-0000');
    </script>
}